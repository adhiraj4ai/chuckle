{
  "name": "@signoff/superpowers-hook",
  "version": "0.1.2",
  "description": "SignOff PreToolUse hook — gates implementation behind vault approval",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "signoff-gate": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
