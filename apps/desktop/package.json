{
  "name": "@chuckle/desktop",
  "version": "0.1.0",
  "description": "Chuckle desktop app — vault UI for document review and approval",
  "author": "Rajan Adhikari",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:installer": "electron-vite build && npx --yes electron-builder@26 --mac dmg",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "vitest run --config vitest.node.config.ts && vitest run --config vitest.config.ts",
    "test:main": "vitest run --config vitest.node.config.ts",
    "test:renderer": "vitest run --config vitest.config.ts"
  },
  "build": {
    "appId": "com.denzing.signoff",
    "productName": "SignOff",
    "electronVersion": "34.5.8",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "npmRebuild": false,
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "identity": null
    }
  },
  "dependencies": {
    "@chuckle/vault-core": "*",
    "mermaid": "^11.16.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^34.0.0",
    "electron-vite": "^3.0.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
